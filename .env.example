# AgendaOk Environment Variables Example
# Duplicate this file and rename it to '.env' for development.

NODE_ENV='development'
PORT='3000'

# Database (PostgreSQL)
DB_HOST='localhost'
DB_PORT='5432'
DB_USER='postgres'
DB_PASSWORD='password'
DB_NAME='agendaok'

# Redis (BullMQ)
REDIS_HOST='redis'
REDIS_PORT='6379'
REDIS_PASSWORD=''

# Google Calendar API (Google Cloud Console)
GOOGLE_CLIENT_ID='your-client-id.apps.googleusercontent.com'
GOOGLE_CLIENT_SECRET='your-client-secret'
GOOGLE_REDIRECT_URI='http://localhost:3000/auth/google/callback'

# Evolution API (WhatsApp Integration)
EVO_DATABASE_NAME='evolution'
EVO_SERVER_URL='http://localhost:8080'
EVO_API_KEY='your_secure_global_key'
EVOLUTION_API_URL='http://evolution-api:8080' # Chamada interna via container

