# ─────────────────────────────────────────
# AgendaOk — Variáveis de Ambiente
# ─────────────────────────────────────────
# Copie este arquivo para .env e preencha os valores.
# Em produção, use secrets management ou variáveis do Swarm.

# ── Aplicação ───────────────────────────
NODE_ENV='development'           # development | production
PORT='3000'
LOG_LEVEL='info'                 # fatal | error | warn | info | debug | trace
DOMAIN='api.agendaok.com.br'    # Domínio público (usado pelo Traefik e Swagger)

# ── Banco de Dados (PostgreSQL) ─────────
# Em produção com bare metal, use o IP do host ou host.docker.internal
DB_HOST='database'               # dev: 'database' | prod: 'host.docker.internal'
DB_PORT='5432'
DB_USER='postgres'
DB_PASSWORD='your_secure_password'
DB_NAME='agendaok'

# ── Redis (BullMQ & Cache) ──────────────
REDIS_HOST='redis'
REDIS_PORT='6379'
REDIS_PASSWORD=''                # Definir em produção

# ── Google Calendar API ─────────────────
# Obtenha em: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID='your-client-id.apps.googleusercontent.com'
GOOGLE_CLIENT_SECRET='your-client-secret'
GOOGLE_REDIRECT_URI='http://localhost:3000/api/auth/google/callback'
# Produção: https://DOMAIN/api/auth/google/callback

# ── Evolution API (WhatsApp) ────────────
EVO_DATABASE_NAME='evolution'
EVO_SERVER_URL='http://localhost:8080'
EVO_API_KEY='your_secure_api_key'
EVOLUTION_API_URL='http://evolution-api:8080'
EVO_DOMAIN='evo.api.agendaok.com.br'   # Subdomínio para Evolution API
